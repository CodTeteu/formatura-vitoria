{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "VITE_BASE_PATH=/formatura-vitoria/ npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/formatura-vitoria/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/formatura-vitoria",
      "destination": "/"
    },
    {
      "source": "/formatura-vitoria/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 0 * * 0,4"
    }
  ]
}
